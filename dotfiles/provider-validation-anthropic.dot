digraph provider_validation_anthropic {
    graph [goal="Validate codergen runtime live with the Anthropic provider"]

    start [shape=Mdiamond]
    validate [
        shape=box,
        provider="anthropic",
        model="claude-sonnet-4-6",
        reasoning_effort="medium",
        timeout="180s",
        node_kind="implementation",
        require_verification="true",
        prompt="Validate the codergen runtime. Required steps: 1. Use the write_file tool or apply_patch tool, not shell redirection, to create logs/provider-validation/anthropic-validation.txt containing two short lines: provider=anthropic and result=PASS. 2. Run dotnet build src/JcAttractor.Attractor/JcAttractor.Attractor.csproj --nologo --no-restore. 3. Return valid stage status JSON with status=success only if both steps succeeded. Include notes that mention the file path and build result. Set context_updates.validation.provider=anthropic and context_updates.validation.marker=PASS."
    ]
    done [shape=Msquare]

    start -> validate
    validate -> done
}
